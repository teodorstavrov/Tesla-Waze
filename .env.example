# ─── Infrastructure ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme123
REDIS_URL=redis://redis:6379

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DATABASE_URL=postgresql://postgres:changeme123@postgres:5432/tesla_intelligence
