# ─── External APIs ────────────────────────────────────────────────────────────
# Waze live map (no key required, public endpoint)
WAZE_BASE_URL=https://www.waze.com/live-map/api

# TomTom Traffic API (free tier: 2500 req/day)
# Get key at: https://developer.tomtom.com/
TOMTOM_API_KEY=

# OpenChargeMap (free, no key needed for basic use)
# Get key at: https://openchargemap.org/site/develop/api
OPENCHARGEMAP_API_KEY=

# HERE Maps (optional, for enhanced geocoding)
HERE_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
